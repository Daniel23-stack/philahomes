# PostgreSQL (required for local dev and Vercel).
# Docker (see docker-compose.yml): postgresql://philahomes:philahomes@localhost:5432/philahomes?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/philahomes?schema=public"

NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: admin password for prisma/seed.js (default admin123)
# ADMIN_PASSWORD=""

# AI support chatbot (optional). Get a key at https://platform.openai.com/api-keys
# If unset, the chat widget still appears but will ask users to use the contact form.
OPENAI_API_KEY=""
