# PostgreSQL (required for local dev and Vercel).
#
# Local Docker (see docker-compose.yml):
# DATABASE_URL="postgresql://philahomes:philahomes@localhost:5432/philahomes?schema=public"
#
# Hosted Neon (Dashboard → your project → Connection string → copy URI; use pooled for app, or direct for heavy migrations):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
#
# Copy this file to ".env.local", fill values, and add the same variable names in Vercel (no file upload—paste each key).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Optional: admin password for prisma/seed.js (default admin123)
# ADMIN_PASSWORD=""

# AI support chatbot (optional). Get a key at https://platform.openai.com/api-keys
# If unset, the chat widget still appears but will ask users to use the contact form.
OPENAI_API_KEY=""
